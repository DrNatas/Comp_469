    "# 03: Task-Specific Input Transformations\n",
    "\n",
    "Implement traversal-style input transformations (Eq. 2, 3, 5 from Radford's paper) for diverse NLP tasks.\n",
    "\n",
    "The key insight is that all task inputs are converted to sequence format compatible with our pre-trained Transformer."
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Task 1: Textual Entailment (Eq. 1)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# =====================================================\n",
    "# 03.1: Textual Entailment Transformation\n",
    "# =====================================================\n",
    "\n",
    "def create_textual_entailment_input(premise, hypothesis):\n",
    "    \"\"\"\n",
    "    Create input sequence for textual entailment task.\n",
    "    \n",
    "    Args:\n",
    "        premise: The premise statement\n",
    "        hypothesis: The hypothesis statement\n",
    "    \n",
    "    Returns:\n",
    "        input_ids: List of token IDs\n",
    "        position_ids: List of position indices\n",
    "    \"\"\"\n",
    "    # Convert to tokens\n",
    "    premise_tokens = tokenize(premise)\n",
    "    hypothesis_tokens = tokenize(hypothesis)\n",
    "    \n",
    "    # Pad/clip to max length\n",
    "    if len(premise_tokens) > MAX_LEN:\n",
    "        premise_tokens = premise_tokens[:MAX_LEN]\n",
    "        hypothesis_tokens = hypothesis_tokens[:MAX_LEN]\n",
    "    \n",
    "    # Create sequence: [premise; $; hypothesis]\n",
    "    sequence = premise_tokens + [tokenizer.sep_token_id] + hypothesis_tokens\n",
    "    \n",
    "    # Convert to IDs and add padding\n",
    "    input_ids = [vocab.word2idx.get(t, 0) for t in sequence]\n",
    "    attention_mask = [1 for t in sequence] + [0 for t in sequence]\n",
    "    \n",
    "    return input_ids, attention_mask\n",
    "\n",
    "# Test the function\n",
    "premise = \"The president signed a new law regarding tax reform.\".lower()\n",
    "hypothesis = \"There will be more tax credits if you pay less.\".lower()\n",
    "\n",
    "input_ids, attention_mask = create_textual_entailment_input(premise, hypothesis)\n",
    "print(f\"Premise ({len(premise_tokens)} tokens): {premise_tokens[:5]}\")\n",
    "print(f\"Hypothesis ({len(hypothesis_tokens)} tokens): {hypothesis_tokens[:5]}\")\n",
    "print(f\"Combined sequence: {sequence}\")\n",
    "print(f\"Input IDs: {input_ids}\")\n",
    "print(f\"Attention mask: {attention_mask}\")\n",
    "\n",
    "# Save the function to file for easy reuse\n",
    "import tempfile\n",
    "with tempfile.NamedTemporaryFile(mode='w', suffix='.py', delete=False) as f:\n",
    "    f.write(\"\"\"def create_textual_entailment_input(premise, hypothesis):\n",
    "    \\\"\\\"\\\"Create input sequence for textual entailment task.\\\"\\\"\\\"\n",
    "    # Convert to tokens\n",
    "    premise_tokens = tokenize(premise)\n",
    "    hypothesis_tokens = tokenize(hypothesis)\n",
    "    \n",
    "    # Pad/clip to max length\n",
    "    if len(premise_tokens) > MAX_LEN:\n",
    "        premise_tokens = premise_tokens[:MAX_LEN]\n",
    "        hypothesis_tokens = hypothesis_tokens[:MAX_LEN]\n",
    "    \n",
    "    # Create sequence: [premise; $; hypothesis]\n",
    "    sequence = premise_tokens + [tokenizer.sep_token_id] + hypothesis_tokens\n",
    "    \n",
    "    # Convert to IDs and add padding\n",
    "    input_ids = [vocab.word2idx.get(t, 0) for t in sequence]\n",
    "    attention_mask = [1 for t in sequence] + [0 for t in sequence]\n",
    "    \n",
    "    return input_ids, attention_mask\n\"\"\")\n",
    "    print(f\"Saved to: {f.name}\")"
   ]
