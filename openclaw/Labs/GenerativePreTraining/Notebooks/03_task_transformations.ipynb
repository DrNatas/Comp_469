    "# =====================================================\n",
    "# 03.4: Create helper functions for dataset preparation\n",
    "# =====================================================\n",
    "\n",
    "def prepare_task_data(data):\n",
", "    \"\"\"Prepare data for a specific task.\"\"\"\n",
", "    if data[\"type\"] == \"entailment\":\n",
", "        # Textual entailment: (premise, hypothesis)\n",
", "        input_ids, attention_mask = [], []\n",
", "        for premise, hypothesis in data:\n",
", "            # Pad sequences\n",
", "            premise_tokens = tokenize(premise)\n",
", "            hypothesis_tokens = tokenize(hypothesis)\n",
", "            if len(premise_tokens) > MAX_LEN:\n",
", "                premise_tokens = premise_tokens[:MAX_LEN]\n",
", "                hypothesis_tokens = hypothesis_tokens[:MAX_LEN]\n",
", "            sequence = premise_tokens + [tokenizer.sep_token_id] + hypothesis_tokens\n",
", "            input_ids.extend([vocab.word2idx.get(t, 0) for t in sequence])\n",
", "            attention_mask.extend([1 for t in sequence] + [0 for _ in sequence])\n",
", "        return input_ids, attention_mask\n",
", "    elif data[\"type\"] == \"similarity\":\n",
", "        # Semantic similarity: (sentence1, sentence2)\n",
", "        input_ids, attention_mask = [], []\n",
", "        for sentence1, sentence2 in data:\n",
", "            sequence1 = tokenize(sentence1)\n",
", "            sequence2 = tokenize(sentence2)\n",
", "            if len(sequence1) > MAX_LEN:\n",
", "                sequence1 = sequence1[:MAX_LEN]\n",
", "                sequence2 = sequence2[:MAX_LEN]\n",
", "            input_ids1.extend([vocab.word2idx.get(t, 0) for t in sequence1])\n",
", "            attention_mask1.extend([1 for t in sequence1] + [0 for _ in sequence1])\n",
", "            input_ids2.extend([vocab.word2idx.get(t, 0) for t in sequence2])\n",
", "            attention_mask2.extend([1 for t in sequence2] + [0 for _ in sequence2])\n",
", "        return input_ids1, attention_mask1, input_ids2, attention_mask2\n",
", "    elif data[\"type\"] == \"qa\":\n",
", "        # Question answering\n",
", "        input_ids, attention_mask = [], []\n",
", "        for context, question, answers in data:\n",
", "            sequence = tokenize(context)\n",
", "            sequence = sequence + [tokenizer.sep_token_id] + [str(ans) for ans in answers]\n",
", "            input_ids.extend([vocab.word2idx.get(t, 0) for t in sequence])\n",
", "            attention_mask.extend([1 for t in sequence])\n",
", "        return input_ids, attention_mask\n",
", "    else:\n",
", "        raise ValueError(f\"Unknown task type: {data['type']}\")\n",
", "    \n",
", "# Save the prepare_task_data function for use in other notebooks\n",
", "with tempfile.NamedTemporaryFile(mode='w', suffix='.py', delete=False) as f:\n",
", "    f.write(\"\"\"def prepare_task_data(data):\n",
", \"    \\\"\\\"\\\"Prepare data for a specific task.\\\"\\\"\\\"\n",
", \"    if data['type'] == 'entailment':\n",
", \"        input_ids, attention_mask = [], []\n",
", \"        for premise, hypothesis in data:\n",
", "            premise_tokens = tokenize(premise)\n",
", "            hypothesis_tokens = tokenize(hypothesis)\n",
", "            if len(premise_tokens) > MAX_LEN:\n",
", "                premise_tokens = premise_tokens[:MAX_LEN]\n",
", "                hypothesis_tokens = hypothesis_tokens[:MAX_LEN]\n",
", "            sequence = premise_tokens + [tokenizer.sep_token_id] + hypothesis_tokens\n",
", "            input_ids.extend([vocab.word2idx.get(t, 0) for t in sequence])\n",
", "            attention_mask.extend([1 for t in sequence] + [0 for _ in sequence])\n",
", "        return input_ids, attention_mask\n",
", "    elif data['type'] == 'similarity':\n",
", "        input_ids, attention_mask = [], []\n",
", "        for sentence1, sentence2 in data:\n",
", "            sequence1 = tokenize(sentence1)\n",
", "            sequence2 = tokenize(sentence2)\n",
", "            if len(sequence1) > MAX_LEN:\n",
", "                sequence1 = sequence1[:MAX_LEN]\n",
", "                sequence2 = sequence2[:MAX_LEN]\n",
", "            input_ids1.extend([vocab.word2idx.get(t, 0) for t in sequence1])\n",
", "            attention_mask1.extend([1 for t in sequence1] + [0 for _ in sequence1])\n",
", "            input_ids2.extend([vocab.word2idx.get(t, 0) for t in sequence2])\n",
", "            attention_mask2.extend([1 for t in sequence2] + [0 for _ in sequence2])\n",
", "        return input_ids1, attention_mask1, input_ids2, attention_mask2\n",
", "    elif data['type'] == 'qa':\n",
", "        input_ids, attention_mask = [], []\n",
", "        for context, question, answers in data:\n",
", "            sequence = tokenize(context)\n",
", "            sequence = sequence + [tokenizer.sep_token_id] + [str(ans) for ans in answers]\n",
", "            input_ids.extend([vocab.word2idx.get(t, 0) for t in sequence])\n",
", "            attention_mask.extend([1 for t in sequence])\n",
", "        return input_ids, attention_mask\n",
", \"    else:\n",
", "        raise ValueError(f'Unknown task type: {data[\\\"type\\\"]}')\n\",\"\")\n",
", "    print(f\"Saved to: {f.name}\")"
   ]
