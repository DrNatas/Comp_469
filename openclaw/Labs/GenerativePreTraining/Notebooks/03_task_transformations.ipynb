    "## Task 3: Question Answering (Eq. 4)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# =====================================================\n",
    "# 03.3: Question Answering Transformation\n",
    "# =====================================================\n",
    "\n",
    "def create_qa_input(context, question, answers):\n",
    "    \"\"\"\n",
    "    Create input sequences for question answering.\n",
    "    \n",
    "    Args:\n",
    "        context: Source document\n",
    "        question: The question\n",
    "        answers: Set of possible answers (as strings or token IDs)\n",
    "    \n",
    "    Returns:\n",
    "        input_ids: List of token IDs for all sequences\n",
",
", "        attention_mask: List of 1s and 0s\n",
",
", "    \"\"\"\n",
    "    # Convert to tokens\n",
    "    context_tokens = tokenize(context)\n",
    "    question_tokens = tokenize(question)\n",
    "    \n",
    "    # Pad to max length\n",
    "    if len(context_tokens) > MAX_LEN:\n",
    "        context_tokens = context_tokens[:MAX_LEN]\n",
    "        question_tokens = question_tokens[:MAX_LEN]\n",
    "    \n",
", "    # Create sequences for each answer\n",
", "    sequence_data = []\n",
", "    for answer in answers:\n",
", "        sequence = context_tokens + [tokenizer.sep_token_id] + [answer]\n",
", "        sequence_data.append(sequence)\n",
", "    \n",
", "    # Convert to IDs and add padding\n",
", "    input_ids = []\n",
", "    attention_mask = []\n",
", "    for seq in sequence_data:\n",
", "        input_ids.append([vocab.word2idx.get(t, 0) for t in seq])\n",
", "        attention_mask.append([1 for t in seq])\n",
", "    \n",
", "    return input_ids, attention_mask\n",
", "    \n",
", "# Test the function\n",
", "context = \"The movie Titanic was a disaster on February 1, 1912.\"\n",
", "question = \"Who starred in Titanic?\"\n",
", "answers = [\"Jack Whitehall\", \"Leonardo DiCaprio\", \"Kathy Najmi\"]\n",
", "\n",
", "input_ids, attn_mask = create_qa_input(context, question, answers)\n",
", "print(f\"Context ({len(context_tokens)} tokens): {context[:20]}...\")\n",
", "print(f\"Question ({len(question_tokens)} tokens): {question}\")\n",
", "print(f\"\\nAnswer sequences:\")\n",
", "for i, answer in enumerate(answers, 1):\n",
", "    print(f\"  Answer {i}: {answer}\")\n",
", "    print(f\"    Sequence: {context_tokens + [tokenizer.sep_token_id] + [answer]}\")\n",
", "    print(f\"    Input IDs: {input_ids[i]}\")\n",
", "    print(f\"    Attention mask: {attn_mask[i]}\")"
   ]
  },
