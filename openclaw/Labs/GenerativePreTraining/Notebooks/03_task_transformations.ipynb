    "## Task 2: Semantic Similarity (Eq. 3)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# =====================================================\n",
    "# 03.2: Semantic Similarity Transformation\n",
    "# =====================================================\n",
    "\n",
    "def create_similarity_input(sentence1, sentence2):\n",
    "    \"\"\"\n",
    "    Create input sequences for semantic similarity task.\n",
    "    \n",
    "    Args:\n",
    "        sentence1: First sentence\n",
    "        sentence2: Second sentence\n",
    "    \n",
    "    Returns:\n",
    "        input_ids: List of token IDs for both orderings\n",
",
    "        attention_mask: List of 1s and 0s\n",
",
    "    \"\"\"\n",
    "    # Convert to tokens\n",
    "    s1_tokens = tokenize(sentence1)\n",
    "    s2_tokens = tokenize(sentence2)\n",
    "    \n",
    "    # Pad to max length\n",
    "    if len(s1_tokens) > MAX_LEN:\n",
    "        s1_tokens = s1_tokens[:MAX_LEN]\n",
    "        s2_tokens = s2_tokens[:MAX_LEN]\n",
    "    if len(s2_tokens) > MAX_LEN:\n",
    "        s2_tokens = s2_tokens[:MAX_LEN]\n",
    "    \n",
    "    # Create both orderings with padding\n",
    "    sequence1 = s1_tokens + [tokenizer.sep_token_id] + s2_tokens\n",
    "    sequence2 = s2_tokens + [tokenizer.sep_token_id] + s1_tokens\n",
    "    \n",
    "    # Convert to IDs and add padding\n",
    "    input_ids1 = [vocab.word2idx.get(t, 0) for t in sequence1]\n",
    "    input_ids2 = [vocab.word2idx.get(t, 0) for t in sequence2]\n",
    "    attention_mask1 = [1 for t in sequence1] + [0 for t in sequence1]\n",
    "    attention_mask2 = [1 for t in sequence2] + [0 for t in sequence2]\n",
    "    \n",
    "    return input_ids1, attention_mask1, input_ids2, attention_mask2\n",
    "\n",
    "# Test the function\n",
    "sentence1 = \"The cat sat on the mat.\"\n",
    "sentence2 = \"The mat was on the cat.\"\n",
    "\n",
    "input_ids1, attn_mask1, input_ids2, attn_mask2 = create_similarity_input(sentence1, sentence2)\n",
    "print(f\"Sentence 1 ({len(s1_tokens)} tokens): {s1_tokens}\")\n",
    "print(f\"Sentence 2 ({len(s2_tokens)} tokens): {s2_tokens}\")\n",
    "print(f\"\\nSentence 1 input IDs: {input_ids1}\")\n",
    "print(f\"Attention mask 1: {attn_mask1}\")\n",
    "print(f\"\\nSentence 2 input IDs: {input_ids2}\")\n",
    "print(f\"Attention mask 2: {attn_mask2}\")\n",
    "print(f\"\\nSequence 1: {sequence1}\")\n",
    "print(f\"Sequence 2: {sequence2}\")"
   ]
  },
