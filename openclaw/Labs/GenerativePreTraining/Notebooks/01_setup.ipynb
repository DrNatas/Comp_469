## 09: Training Loop

```python
def train_epoch(model, dataloader, optimizer, device, num_epochs=100):
    """Train for one epoch."""
    model.train()
    losses = []
    
    for batch in dataloader:
        input_ids = batch["input_ids"].long()
        position_ids = batch["position_ids"].long()
        label = batch["labels"].long()
        
        optimizer.zero_grad()
        logits = model(input_ids, position_ids, torch.ones_like(input_ids)).squeeze(-1)
        
        loss = compute_loss(logits, label)
        loss.backward()
        
        # Gradient clipping
        torch.nn.utils.clip_grad_norm_(model.parameters(), 5.0)
        
        optimizer.step()
        
        losses.append(loss.item())
    
    return np.mean(losses)


def train(model, corpus, dataloader, optimizer, scheduler, num_epochs=100):
    """Train language model."""
    losses = []
    
    for epoch in range(num_epochs):
        loss = train_epoch(model, dataloader, optimizer, device, num_epochs)
        losses.append(loss)
        
        # Reduce LR (warmup)
        warmup_lr = (epoch + 1) / (num_epochs * 100)
        optimizer.step()
        scheduler.step(loss)
        
        if (epoch + 1) % 10 == 0:
            print(f"Epoch {epoch + 1}/{num_epochs}, Loss: {loss:.4f}")
    
    return np.mean(losses)


