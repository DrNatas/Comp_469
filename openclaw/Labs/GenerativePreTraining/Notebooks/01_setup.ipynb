## 04: Simple Word Embeddings

```python
class SimpleWordEmbedding:
    """Simple word embedding (like BERT word2vec)."""
    
    def __init__(self, embedding_dim, vocab_size):
        """
        Args:
            embedding_dim: Embedding dimension
            vocab_size: Vocabulary size
        """
        self.embedding_dim = embedding_dim
        self.vocab_size = vocab_size
        self.weight = nn.Embedding(vocab_size, embedding_dim)
        self.init_weights()
    
    def init_weights(self):
        """Random initialization: W ~ N(0, 0.02)."""
        self.weight.data.uniform_(-0.02, 0.02)
    
    def encode(self, word):
        """Encode word to embedding."""
        word_idx = vocabulary.word2idx.get(word, vocabulary.word2idx["<UNK>"])
        return self.weight(word_idx).float()
```

## 05: Simple Token Embedding

```python
class TokenEmbedding:
    """Embed token sequences."""
    
    def __init__(self, vocab_size, embed_dim, position_encoding_dim):
        """
        Args:
            vocab_size: Vocabulary size
            embed_dim: Embedding dimension
            position_encoding_dim: Position encoding dimension (learned)
        """
        self.word_embeddings = nn.Embedding(vocab_size, embed_dim)
        self.position_encoding = nn.Embedding(max_len, position_encoding_dim)
        self.init_weights()
    
    def init_weights(self):
        self.word_embeddings.weight.data.uniform_(-0.02, 0.02)
    
    def encode(self, tokens):
        """Encode sequence of tokens."""
        # Use learned position encoding for each token
        return self.word_embeddings(tokens) + self.position_encoding(tokens)
```

