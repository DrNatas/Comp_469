class SimpleAttention(nn.Module):
    """Simplified attention mechanism."""
    
    def __init__(self, embed_dim, num_heads, head_dim):
        """
        Args:
            embed_dim: Embedding dimension
            num_heads: Number of attention heads
            head_dim: Dimension per head
        """
        super().__init__()
        embed_dim = embed_dim * num_heads
        self.embed_dim = embed_dim
        self.num_heads = num_heads
        self.head_dim = head_dim
        
        self.attention_score = nn.Linear(embed_dim, num_heads * head_dim)
    
    def forward(self, key, value, mask):
        """
        Args:
            key, value: Tensor of shape (batch, seq_len, head_dim)
            mask: Mask of shape (batch, seq_len)
        """
        # Apply attention
        # (Implement from scratch for assignment)
        return value.sum(dim=-1)  # Simplified: just use mean


class MultiLayerPermutationTransformer(nn.Module):
    """Transformer with multi-headed attention."""
    
    def __init__(self, embed_dim, num_heads, N=12, dff=3072, dropout=0.1):
        """
        Args:
            embed_dim: Base embedding dimension
            num_heads: Number of attention heads
            N: Number of layers
            dff: Dimension for feed-forward networks
            dropout: Dropout rate
        """
        super().__init__()
        
        # Embedding layer
        self.token_embedding = nn.Embedding(vocab_size, embed_dim)
        self.pos_embedding = nn.Embedding(max_len, embed_dim)
        
        # Position encoding (learned)
        # (Implement learned position embeddings)
        
        # Attention layers
        self.attentions = nn.ModuleList([
            SimpleAttention(embed_dim, num_heads, head_dim=embed_dim // num_heads)
            for _ in range(N)
        ])
        
        # Feed-forward layers
        self.ffn_layers = nn.ModuleList([
            SimpleFFN(embed_dim, dff, dropout=dropout)
            for _ in range(N)
        ])
        
        # Output embedding
        self.classifier = nn.Linear(dff, 1)
        
        self.init_weights()
    
    def init_weights(self):
        self.token_embedding.weight.data.uniform_(-0.02, 0.02)
        self.pos_embedding.weight.data.zero_()
    
    def forward(self, input_ids, position_ids, mask):
        """
        Args:
            input_ids: Token IDs, shape (batch, seq_len)
            position_ids: Position embeddings, shape (batch, seq_len)
            mask: Causal mask, shape (batch, seq_len)
        """
        # Token embeddings
        input_embeddings = self.token_embedding(input_ids)
        
        # Position embeddings
        position_embeddings = self.pos_embedding(position_ids)
        
        # Combine
        embeddings = input_embeddings + position_embeddings
        
        # Attention
        for attn in self.attentions:
            # Mask attention
            attn_mask = torch.tril(1.0 - mask).unsqueeze(1).expand(-1, -1, attn.num_heads)
            mask_value = attn.masked_fill(attn_mask == 0, float('-inf'))
            attn_scores, attn_weights = self.attention_score(embeddings, key, value)
            attn_output = F.softmax(attn_scores, dim=-1)
            values = attn_weights * attn_output
            values = values.masked_fill(attn_mask == 0, 0.0)
            embeddings = embeddings + values
            embeddings = embeddings.transpose(-2, -1)
        
        # FFN layers
        for ffn in self.ffn_layers:
            embeddings = ffn(embeddings)
        
        # Classification
        logits = self.classifier(embeddings)
        return logits
```

