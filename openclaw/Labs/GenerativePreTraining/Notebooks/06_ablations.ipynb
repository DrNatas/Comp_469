    "## Implementation Code from Paper\n",
    "\n",
", "### Section 3.1: Unsupervised Pre-Training\n",
", "```python\n",
", "# Pre-training code from paper (simplified for this assignment)\n",
", "\n",
", "class PreTrainingModel(nn.Module):\n",
", "    \"\"\"Pre-trained Transformer.\"\"\"\n",
", "    \n",
", "    def __init__(self, embed_dim, num_heads, N=12, dff=3072, dropout=0.1):\n",
", "        \"\"\"\n",
", "        Args:\n",
", "            embed_dim: Base embedding dimension\n",
", "            num_heads: Number of attention heads\n",
", "            N: Number of transformer layers\n",
", "            dff: Dimension for feed-forward networks\n",
", "            dropout: Dropout rate\n",
", "        \"\"\"\n",
", "        super().__init__()\n",
", "        \n",
", "        # Token embedding\n",
", "        self.token_embedding = nn.Embedding(max_vocab_size, embed_dim)\n",
", "        \n",
", "        # Position embedding (learned)\n",
", "        self.position_embedding = nn.Embedding(max_len, embed_dim)\n",
", "        \n",
", "        # Attention layers\n",
", "        self.attentions = nn.ModuleList([\n",
", "            Attention(embed_dim, num_heads, head_dim=embed_dim // num_heads, dropout=dropout)\n",
", "            for _ in range(N)\n",
", "        ])\n",
", "        \n",
", "        # Feed-forward layers\n",
", "        self.ffn_layers = nn.ModuleList([\n",
", "            FeedForward(embed_dim, dff, dropout=dropout)\n",
", "            for _ in range(N)\n",
", "        ])\n",
", "        \n",
", "        # Output classification\n",
", "        self.classifier = nn.Linear(dff, 1)\n",
", "        \n",
", "        # Initialize weights (normal distribution)\n",
", "        self.apply(self._init_weights)\n",
", "    \n",
", "    def _init_weights(self, module):\n",
", "        \"\"\"Random initialization: W ~ N(0, 0.02).\"\"\"\n",
", "        for m in module.values():\n",
", "            if isinstance(m, nn.Linear):\n",
", "                m.weight.data.normal_(0, 0.02)\n",
", "            elif isinstance(m, nn.Embedding):\n",
", "                m.weight.data.normal_(0, 0.02)\n",
", "    \n",
", "    def forward(self, input_ids, position_ids, mask):\n",
", "        \"\"\"\n",
", "        Args:\n",
", "            input_ids: Token IDs, shape (batch, seq_len)\n",
", "            position_ids: Position embeddings, shape (batch, seq_len)\n",
", "            mask: Causal mask, shape (batch, seq_len)\n",
", "        \"\"\"\n",
", "        # Token embeddings\n",
", "        input_embeddings = self.token_embedding(input_ids)\n",
", "        \n",
", "        # Position embeddings\n",
", "        position_embeddings = self.position_embedding(position_ids)\n",
", "        \n",
", "        # Combine\n",
", "        embeddings = input_embeddings + position_embeddings\n",
", "        \n",
", "        # Apply attention layers\n",
", "        for attn in self.attentions:\n",
", "            attn_mask = torch.tril(1.0 - mask).unsqueeze(1).expand(-1, -1, attn.num_heads)\n",
", "            mask_value = attn.masked_fill(attn_mask == 0, float('-inf'))\n",
", "            attn_scores, attn_weights = attn.attention_score(embeddings, key, value)\n",
", "            attn_output = F.softmax(attn_scores, dim=-1)\n",
", "            values = attn_weights * attn_output\n",
", "            values = values.masked_fill(attn_mask == 0, 0.0)\n",
", "            embeddings = embeddings + values\n",
", "            embeddings = embeddings.transpose(-2, -1)\n",
", "        \n",
", "        # Feed-forward layers\n",
", "        for ffn in self.ffn_layers:\n",
", "            embeddings = ffn(embeddings)\n",
", "        \n",
", "        # Classification\n",
", "        logits = self.classifier(embeddings)\n",
", "        return logits\n",
", "    \n",
", "    def _init_weights(self, module):\n",
", "        \"\"\"Random initialization: W ~ N(0, 0.02).\"\"\"\n",
", "        for m in module.values():\n",
", "            if isinstance(m, nn.Linear):\n",
", "                m.weight.data.normal_(0, 0.02)\n",
", "            elif isinstance(m, nn.Embedding):\n",
", "                m.weight.data.normal_(0, 0.02)\n",
", "    \n",
", "    def forward(self, input_ids, position_ids, mask):\n",
", "        \"\"\"\n",
", "        Args:\n",
", "            input_ids: Token IDs, shape (batch, seq_len)\n",
", "            position_ids: Position embeddings, shape (batch, seq_len)\n",
", "            mask: Causal mask, shape (batch, seq_len)\n",
", "        \"\"\"\n",
", "        # Token embeddings\n",
", "        input_embeddings = self.token_embedding(input_ids)\n",
", "        \n",
", "        # Position embeddings\n",
", "        position_embeddings = self.position_embedding(position_ids)\n",
", "        \n",
", "        # Combine\n",
", "        embeddings = input_embeddings + position_embeddings\n",
", "        \n",
", "        # Apply attention layers\n",
", "        for attn in self.attentions:\n",
", "            attn_mask = torch.tril(1.0 - mask).unsqueeze(1).expand(-1, -1, attn.num_heads)\n",
", "            mask_value = attn.masked_fill(attn_mask == 0, float('-inf'))\n",
", "            attn_scores, attn_weights = attn.attention_score(embeddings, key, value)\n",
", "            attn_output = F.softmax(attn_scores, dim=-1)\n",
", "            values = attn_weights * attn_output\n",
", "            values = values.masked_fill(attn_mask == 0, 0.0)\n",
", "            embeddings = embeddings + values\n",
", "            embeddings = embeddings.transpose(-2, -1)\n",
", "        \n",
", "        # Feed-forward layers\n",
", "        for ffn in self.ffn_layers:\n",
", "            embeddings = ffn(embeddings)\n",
", "        \n",
", "        # Classification\n",
", "        logits = self.classifier(embeddings)\n",
", "        return logits\n",
", "```"
