    "### Section 3.2: Supervised Fine-Tuning\n",
", "```python\n",
", "# Fine-tuning code from paper (simplified for this assignment)\n",
", "\n",
", "def train_task(model, task_data, input_ids, attention_mask, labels, device, optimizer, lr=6.25e-5, epochs=3, lambda_aux=0.5):\n",
", "    \"\"\"\n",
", "    Train on a specific task.\n",
", "    \n",
", "    Args:\n",
", "        model: Pre-trained transformer\n",
", "        task_data: Dataset with (input, label) tuples\n",
", "        input_ids, attention_mask: Input sequences from traversal-style transformation\n",
", "        labels: Supervised labels\n",
", "        device: Training device\n",
", "        lr: Learning rate\n",
", "        epochs: Training epochs\n",
", "        lambda_aux: Auxiliary weight\n",
", "    \"\"\"\n",
", "    # Initialize\n",
", "    optimizer = torch.optim.Adam(model.parameters(), lr=lr)\n",
", "    \n",
", "    for epoch in range(epochs):\n",
", "        # Forward pass\n",
", "        model.eval()\n",
", "        with torch.no_grad():\n",
", "            logits = model(input_ids, attention_mask, torch.ones_like(input_ids)).squeeze(-1)\n",
", "        \n",
", "        # Supervised loss\n",
", "        supervised_loss = F.cross_entropy(logits, labels, reduction='none')\n",
", "        \n",
", "        # Auxiliary loss (language modeling)\n",
", "        position_ids = torch.arange(input_ids.size(1)).to(device)\n",
", "        mask = torch.ones_like(input_ids)\n",
", "        aux_loss = F.cross_entropy(model(input_ids, position_ids, mask).squeeze(-1), vocab)\n",
", "        \n",
", "        # Combined loss\n",
", "        loss = supervised_loss + lambda_aux * aux_loss\n",
", "        \n",
", "        # Backward pass\n",
", "        loss.backward()\n",
", "        \n",
", "        # Gradient clipping\n",
", "        torch.nn.utils.clip_grad_norm_(model.parameters(), 5.0)\n",
", "        \n",
", "        # Step optimizer\n",
", "        optimizer.step()\n",
", "        \n",
", "        print(f\"{task_name.capitalize()} Epoch {epoch + 1}/{epochs}, Supervised: {supervised_loss.mean().item():.4f}, Aux: {aux_loss.item():.4f}, Total: {loss.item():.4f}\")\n",
", "    \n",
", "    return supervised_loss.mean().item()\n",
", "```"
   ]
