    "## Section 3.3: Task-Specific Input Transformations\n",
", "```python\n",
", "def create_textual_entailment_input(premise, hypothesis):\n",
", "    \"\"\"\n",
", "    Create input sequence for textual entailment task.\n",
", "    \n",
", "    Args:\n",
", "        premise: The premise statement\n",
", "        hypothesis: The hypothesis statement\n",
", "    \"\"\"\n",
", "    premise_tokens = tokenize(premise)\n",
", "    hypothesis_tokens = tokenize(hypothesis)\n",
", "    \n",
", "    # Pad to max length\n",
", "    if len(premise_tokens) > MAX_LEN:\n",
", "        premise_tokens = premise_tokens[:MAX_LEN]\n",
", "        hypothesis_tokens = hypothesis_tokens[:MAX_LEN]\n",
", "    \n",
", "    # Create sequence: [premise; $; hypothesis]\n",
", "    sequence = premise_tokens + [tokenizer.sep_token_id] + hypothesis_tokens\n",
", "    \n",
", "    # Convert to IDs\n",
", "    input_ids = [vocab.word2idx.get(t, 0) for t in sequence]\n",
", "    attention_mask = [1 for t in sequence] + [0 for t in sequence]\n",
", "    \n",
", "    return input_ids, attention_mask\n",
", "```"
