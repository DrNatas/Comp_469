   "source": [
    "# 04: Fine-Tuning on Tasks\n",
    "\n",
    "Implement supervised fine-tuning with task-specific input transformations on NLP tasks.\n",
    "\n",
    "The key difference from pre-training is adding task-specific supervision and loss function."
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Task 1: Natural Language Inference (NLI)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# =====================================================\n",
    "# 04.1: NLI Fine-Tuning Setup\n",
    "# =====================================================\n",
    "\n",
    "def fine_tune_for_nli(model, input_ids, attention_mask, labels, device, optimizer, lr=6.25e-5, epochs=3, lambda_aux=0.5, device=torch.device('cpu')):\n",
", "    \"\"\"\n",
", "    Fine-tune model for NLI tasks using Eq. 5:\n",
", "    L3(C) = L2(C) + λ * L1(C)\n",
", "    \n",
", "    Args:\n",
", "        model: Pre-trained transformer\n",
", "        input_ids, attention_mask: Input sequences from traversal-style transformation\n",
", "        labels: Binary labels (0=contradiction, 1=neutral, 2=entailment)\n",
", "        device: Device to train on\n",
", "        lr: Learning rate\n",
", "        epochs: Number of training epochs\n",
", "        lambda_aux: Weight for auxiliary LM loss\n",
", "        device: Device to train on\n",
", "    \"\"\"\n",
", "    # Initialize optimizer\n",
", "    optimizer = torch.optim.Adam(model.parameters(), lr=lr)\n",
", "    \n",
", "    for epoch in range(epochs):\n",
", "        # Forward pass\n",
", "        model.eval()\n",
", "        with torch.no_grad():\n",
", "            logits = model(input_ids, attention_mask, torch.ones_like(input_ids)).squeeze(-1)\n",
", "        \n",
", "        # Compute supervised loss\n",
", "        supervised_loss = F.cross_entropy(logits, labels, reduction='none')\n",
", "        \n",
", "        # Compute auxiliary loss (language modeling)\n",
", "        position_ids = torch.arange(input_ids.size(1)).to(device)\n",
", "        mask = torch.ones_like(input_ids)\n",
", "        aux_loss = F.cross_entropy(model(input_ids, position_ids, mask).squeeze(-1), vocab)\n",
", "        \n",
", "        # Combined loss\n",
", "        loss = supervised_loss + lambda_aux * aux_loss\n",
", "        \n",
", "        # Backward pass\n",
", "        loss.backward()\n",
", "        \n",
", "        # Gradient clipping\n",
", "        torch.nn.utils.clip_grad_norm_(model.parameters(), 5.0)\n",
", "        \n",
", "        # Step optimizer\n",
", "        optimizer.step()\n",
", "        \n",
", "        print(f\"Epoch {epoch + 1}/{epochs}, Supervised Loss: {supervised_loss.item():.4f}, Aux Loss: {aux_loss.item():.4f}, Total Loss: {loss.item():.4f}\")\n",
", "\n",
", "if __name__ == \"__main__\":\n",
", "    # Example usage\n",
", "    # fine_tune_for_nli(model, input_ids, attention_mask, labels, device, optimizer, lr=6.25e-5, epochs=3)\n",
", "    print(\"NLI fine-tuning setup configured\")\n",
", "    print(\"Parameters:\")\n",
", "    print(f\"  Learning rate: 6.25e-5\")\n",
", "    print(f\"  Epochs: 3\")\n",
", "    print(f\"  Auxiliary weight (λ): 0.5\")\n",
", "    print(f\"  Gradient clipping: 5.0\")\n",
", "\n",
", "    # Uncomment when running training\n",
", "    # fine_tune_for_nli(model, input_ids, attention_mask, labels, device, optimizer, lr=6.25e-5, epochs=3, lambda_aux=0.5, device=device)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Task 2: Question Answering and Commonsense Reasoning"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# =====================================================\n",
    "# 04.2: QA and Commonsense Reasoning Setup\n",
    "# =====================================================\n",
    "\n",
    "def fine_tune_for_qa(model, input_ids, attention_mask, labels, device, optimizer, lr=6.25e-5, epochs=3, lambda_aux=0.5):\n",
", "    \"\"\"\n",
", "    Fine-tune model for QA tasks.\n",
", "    \n",
", "    Args:\n",
", "        model: Pre-trained transformer\n",
", "        input_ids, attention_mask: Input sequences\n",
", "        labels: Labels (predicted answer vs ground truth)\n",
", "        device: Training device\n",
", "        lr: Learning rate\n",
", "        epochs: Training epochs\n",
", "        lambda_aux: Auxiliary weight\n",
", "    \"\"\"\n",
", "    optimizer = torch.optim.Adam(model.parameters(), lr=lr)\n",
", "    \n",
", "    for epoch in range(epochs):\n",
", "        model.eval()\n",
", "        with torch.no_grad():\n",
", "            logits = model(input_ids, attention_mask, torch.ones_like(input_ids)).squeeze(-1)\n",
", "        \n",
", "        # Compute supervised loss\n",
", "        supervised_loss = F.cross_entropy(logits, labels, reduction='none')\n",
", "        \n",
", "        # Compute auxiliary loss\n",
", "        position_ids = torch.arange(input_ids.size(1)).to(device)\n",
", "        mask = torch.ones_like(input_ids)\n",
", "        aux_loss = F.cross_entropy(model(input_ids, position_ids, mask).squeeze(-1), vocab)\n",
", "        \n",
", "        loss = supervised_loss + lambda_aux * aux_loss\n",
", "        \n",
", "        loss.backward()\n",
", "        torch.nn.utils.clip_grad_norm_(model.parameters(), 5.0)\n",
", "        optimizer.step()\n",
", "        \n",
", "        print(f\"QA Epoch {epoch + 1}/{epochs}, Supervised: {supervised_loss.item():.4f}, Aux: {aux_loss.item():.4f}, Total: {loss.item():.4f}\")\n",
", "\n",
", "if __name__ == \"__main__\":\n",
", "    print(\"QA fine-tuning setup configured\")\n",
", "    print(\"Parameters:\")\n",
", "    print(f\"  LR: 6.25e-5\")\n",
", "    print(f\"  Epochs: 3\")\n",
", "    print(f\"  Lambda: 0.5\")"
   ]
  },
  {
   "cell_type": "markdown",
