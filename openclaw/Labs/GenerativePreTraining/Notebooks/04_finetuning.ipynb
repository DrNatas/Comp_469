    "# =====================================================\n",
    "# 04.4: Text Classification Setup\n",
    "# =====================================================\n",
    "\n",
    "def fine_tune_for_classification(model, input_ids, attention_mask, labels, device, optimizer, lr=6.25e-5, epochs=3, lambda_aux=0.5):\n",
", "    \"\"\"\n",
", "    Fine-tune model for text classification.\n",
", "    \n",
", "    Args:\n",
", "        model: Pre-trained transformer\n",
", "        input_ids, attention_mask: Input sequences\n",
", "        labels: Binary labels (0/1)\n",
", "        device: Training device\n",
", "        lr: Learning rate\n",
", "        epochs: Training epochs\n",
", "        lambda_aux: Auxiliary weight\n",
", "    \"\"\"\n",
", "    optimizer = torch.optim.Adam(model.parameters(), lr=lr)\n",
", "    \n",
", "    for epoch in range(epochs):\n",
", "        model.eval()\n",
", "        with torch.no_grad():\n",
", "            logits = model(input_ids, attention_mask, torch.ones_like(input_ids)).squeeze(-1)\n",
", "        \n",
", "        # Compute supervised loss\n",
", "        supervised_loss = F.cross_entropy(logits, labels, reduction='none')\n",
", "        \n",
", "        # Compute auxiliary loss\n",
", "        position_ids = torch.arange(input_ids.size(1)).to(device)\n",
", "        mask = torch.ones_like(input_ids)\n",
", "        aux_loss = F.cross_entropy(model(input_ids, position_ids, mask).squeeze(-1), vocab)\n",
", "        \n",
", "        loss = supervised_loss + lambda_aux * aux_loss\n",
", "        \n",
", "        loss.backward()\n",
", "        torch.nn.utils.clip_grad_norm_(model.parameters(), 5.0)\n",
", "        optimizer.step()\n",
", "        \n",
", "        print(f\"Classification Epoch {epoch + 1}/{epochs}, Supervised: {supervised_loss.mean().item():.4f}, Aux: {aux_loss.item():.4f}, Total: {loss.item():.4f}\")\n",
", "\n",
", "if __name__ == \"__main__\":\n",
", "    print(\"Classification fine-tuning setup configured\")\n",
", "    print(\"Parameters:\")\n",
", "    print(f\"  LR: 6.25e-5\")\n",
", "    print(f\"  Epochs: 3\")\n",
", "    print(f\"  Lambda: 0.5\")"
